{
  "expo": {
    "name": "Inventario Cuba",
    "slug": "inventario-cuba",
    "version": "1.0.0",
    "sdkVersion": "51.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1976D2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.inventariocuba.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Para tomar fotos de los productos",
        "NSPhotoLibraryUsageDescription": "Para seleccionar fotos de los productos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#1976D2"
      },
      "package": "com.inventariocuba.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE"
    ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-barcode-scanner",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1976D2",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d0dd43b4-515e-4362-b0c5-ade3c09fb65a"
      }
    },
    "owner": "magidel"
  }
}
